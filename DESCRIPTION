Package: rtmpinvi
Type: Package
Title: Interactive Tabular Matrix Problems via Pseudoinverse Estimation
Version: 0.1.0
Authors@R: 
    c(
        person("Ilya", "Bolotov", email = "ilya.bolotov@vse.cz",
               role = c("aut", "cre"),
               comment = c(ORCID = "0000-0003-1148-7144"))
